<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="Delay Delivery Opt.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser query pragmas" current="2"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1716"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="Food_Delivery_Dataset" custom_title="0" dock_id="5" table="4,21:mainFood_Delivery_Dataset"/><dock_state state=""/><default_encoding codec=""/><browse_table_settings><table schema="main" name="Food_Delivery_Dataset" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="61"/><column index="2" value="80"/><column index="3" value="56"/><column index="4" value="80"/><column index="5" value="82"/><column index="6" value="82"/><column index="7" value="135"/><column index="8" value="141"/><column index="9" value="116"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">-- =========================
-- DATA CLEANING
-- =========================

-- 1. check for duplicates and remove any

SELECT Order_ID , count(*) from Food_Delivery_Dataset 
group by Order_ID having count(*) &gt; 1;

-- 2. standardize data and fix errors

UPDATE Food_Delivery_Dataset
SET 
    Weather = TRIM(Weather),
    Traffic_Level = TRIM(Traffic_Level),
    Time_of_Day = TRIM(Time_of_Day),
    Vehicle_Type = TRIM(Vehicle_Type);

-- 3. Look at null values and see what 

SELECT DISTINCT Weather from Food_Delivery_Dataset;
Update Food_Delivery_Dataset
Set Weather = 'Unknown' 
where Weather is Null or Weather='' ;

SELECT DISTINCT Traffic_Level from Food_Delivery_Dataset;
UPDATE Food_Delivery_Dataset
Set Traffic_Level ='Unknown'
where Traffic_Level is null or Traffic_Level = '';

SELECT DISTINCT Time_of_Day from Food_Delivery_Dataset;
UPDATE Food_Delivery_Dataset
SET Time_of_Day = 'Unknown'
WHERE Time_of_Day IS NULL OR Time_of_Day = '';

SELECT DISTINCT Vehicle_Type from Food_Delivery_Dataset;

-- 4. data type check
PRAGMA table_info(Food_Delivery_Dataset);

SELECT DISTINCT Courier_Experience_yrs
FROM Food_Delivery_Dataset;

Alter table Food_Delivery_Dataset
Add COLUMN Experience_yrs INTEGER;

Update Food_Delivery_Dataset
Set Experience_yrs = Cast(Courier_Experience_yrs as INTEGER);


-- =========================
-- EXPLORATORY DATA ANALYSIS
-- =========================

--What we are looking for : 
-- factors affecting delay delivery and solution for it 

--1. Delivery Distance 
SELECT 
    ROUND(Distance_km, 0) AS distance_group,
    AVG(Delivery_Time_min) AS avg_delivery_time
FROM Food_Delivery_Dataset
GROUP BY distance_group
ORDER BY distance_group;

--Delivery time increases consistently with distance, showing a strong positive relationship

-- 2.Preparation Time  

SELECT 
    Preparation_Time_min,
    AVG(Delivery_Time_min) AS avg_delivery_time
FROM Food_Delivery_Dataset
GROUP BY Preparation_Time_min
ORDER BY Preparation_Time_min;

--Preparation time shows moderate influence but is less impactful than distance and traffic

-- 3.Experience years 

SELECT 
    Experience_yrs,
    AVG(Delivery_Time_min) AS avg_delivery_time
FROM Food_Delivery_Dataset
GROUP BY Experience_yrs
ORDER BY Experience_yrs;

--Courier experience has minimal impact compared to external factors like traffic and distance

-- 4. Weather 

Select 
weather ,
Avg(Delivery_Time_min) as avg_delivery_time 
from Food_Delivery_Dataset
GROUP by weather;

--Weather shows moderate impact on delivery time, especially under adverse conditions

-- 5. Traffic level 

Select 
Traffic_Level ,
Avg(Delivery_time_min) as avg_delivery_time 
from Food_Delivery_Dataset
group by Traffic_Level;

--Traffic has a significant impact on delivery time, with high traffic conditions leading to noticeably longer delivery durations.

-- 6. Time of day 

Select 
Time_of_Day ,
Avg(Delivery_time_min) as avg_delivery_time 
from Food_Delivery_Dataset
group by Time_of_Day;

--Time of day has negligible impact compared to traffic and distance

-- 7. Vehicle Type

Select 
Vehicle_Type ,
Avg(Delivery_time_min) as avg_delivery_time 
from Food_Delivery_Dataset
group by Vehicle_Type;

--Vehicle type contributes little to delivery variation, indicating external factors dominate

-- =========================
-- ADVANCED ANALYSIS
-- =========================

-- Distance + Traffic Combined Impact
SELECT 
    CASE 
        WHEN Distance_km &lt;= 5 THEN 'Short'
        WHEN Distance_km &lt;= 10 THEN 'Medium'
        ELSE 'Long'
    END AS distance_category,
    Traffic_Level,
    AVG(Delivery_Time_min) AS avg_time
FROM Food_Delivery_Dataset
GROUP BY distance_category, Traffic_Level
ORDER BY avg_time DESC;

-- Traffic impact becomes significantly worse as delivery distance increases

-- Best Case Scenario
SELECT 
    Traffic_Level,
    Weather,
    AVG(Delivery_Time_min) AS avg_time
FROM Food_Delivery_Dataset
GROUP BY Traffic_Level, Weather
ORDER BY avg_time ASC
LIMIT 5;

--Fastest deliveries occur under low traffic and clear weather

-- Worst Scenario 

SELECT 
    Traffic_Level,
    COUNT(*) AS total_orders,
    AVG(Delivery_Time_min) AS avg_time,
    MIN(Delivery_Time_min) AS min_time,
    MAX(Delivery_Time_min) AS max_time
FROM Food_Delivery_Dataset
GROUP BY Traffic_Level;

SELECT 
    COUNT(*) AS total_orders,
    SUM(CASE WHEN Delivery_Time_min &gt; 45 THEN 1 ELSE 0 END) * 100.0 / COUNT(*) AS late_delivery_percentage
FROM Food_Delivery_Dataset;

-- Delay category 

SELECT *,
CASE 
    WHEN Delivery_Time_min &lt;= 30 THEN 'On Time'
    WHEN Delivery_Time_min &lt;= 45 THEN 'Slight Delay'
    ELSE 'High Delay'
END AS delivery_status
FROM Food_Delivery_Dataset;

--Categorizing deliveries helps identify patterns in high-delay orders and enables targeted optimization strategies

-- Efficiency Analysis (Time per KM)
SELECT 
    AVG(Delivery_Time_min / Distance_km) AS avg_time_per_km
FROM Food_Delivery_Dataset;

--Evaluates delivery efficiency relative to distance, highlighting route-level inefficiencies

-- Late Delivery by Traffic Level
SELECT 
    Traffic_Level,
    SUM(CASE WHEN Delivery_Time_min &gt; 45 THEN 1 ELSE 0 END) * 100.0 / COUNT(*) AS late_percentage
FROM Food_Delivery_Dataset
GROUP BY Traffic_Level;

--A significant percentage of deliveries exceed the 45-minute threshold, indicating operational inefficiencies primarily driven by traffic conditions

--Traffic impact intensifies with distance; worst delays occur under high traffic + poor weather
--The combination of high traffic and adverse weather conditions leads to the highest delivery delays.
--Even for short distances, high traffic can cause delays comparable to medium-distance deliveries


-- =========================
-- KEY FINDINGS &amp; INSIGHTS
-- =========================

-- Distance and traffic are the primary drivers of delivery delays
-- High traffic increases delivery time significantly across all distances
-- Weather and preparation time have moderate impact
-- Courier-related factors (experience, vehicle type) have minimal influence

--Critical Insight:
-- The worst delays occur when long distances combine with high traffic and poor weather conditions

--Conclusion:
-- Delivery performance is driven more by external conditions than individual courier efficiency.


-- =========================
-- KEY FINDINGS &amp; INSIGHTS
-- =========================

-- 1. Dynamic Order Batching
-- During high-traffic conditions, nearby orders can be grouped and delivered together to reduce the number of trips and improve delivery efficiency.

-- 2. Traffic-Aware ETA &amp; Pricing
---- Adjust delivery time estimates dynamically based on real-time traffic conditions to improve customer trust

-- 3. Smart Courier Allocation
---- Assign experienced couriers specifically to high-distance and high-traffic routes for maximum efficiency impact

-- 4. Micro-Zone Optimization
--Delivery regions can be divided into smaller zones based on delay patterns to reduce variability and improve operational efficiency.

--These strategies can help improve delivery efficiency, reduce delays, and enhance overall customer satisfaction through data-driven decision-making.</sql><current_tab id="0"/></tab_sql></sqlb_project>
